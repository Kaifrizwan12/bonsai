{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run bonsai Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--disable-extension=gornivv.vscode-flutter-files",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    }
  ]
}
